[
  {
    "stepTitle": "${install.stepTitle}",
    "description": "${config.description}",
    "items": [
      {
        "type": "text",
        "field": "wizard_http_port",
        "label": "${install.portLabel}",
        "initValue": "9892",
        "rules": [
          {
            "required": true,
            "message": "${install.portRequiredMsg}"
          },
          {
            "pattern": "^[0-9]{2,5}$",
            "message": "${install.portFormatMsg}"
          }
        ]
      },
      {
        "type": "text",
        "field": "wizard_redis_db",
        "label": "${install.redisDbLabel}",
        "initValue": "2",
        "rules": [
          {
            "required": true,
            "message": "${install.redisDbRequiredMsg}"
          },
          {
            "pattern": "^[0-9]+$",
            "message": "${install.redisDbFormatMsg}"
          }
        ]
      },
      {
        "type": "tips",
        "helpText": "${install.offlineDependenciesHelpText}"
      }
    ]
  },
  {
    "stepTitle": "${install.adminStepTitle}",
    "description": "${config.adminDescription}",
    "items": [
      {
        "type": "text",
        "field": "wizard_admin_username",
        "label": "${install.adminUsernameLabel}",
        "initValue": "admin",
        "rules": [
          {
            "required": true,
            "message": "${install.adminUsernameRequiredMsg}"
          },
          {
            "min": 2,
            "max": 64,
            "message": "${install.adminUsernameLenMsg}"
          }
        ]
      },
      {
        "type": "password",
        "field": "wizard_admin_password",
        "label": "${install.adminPasswordLabel}",
        "rules": [
          {
            "required": true,
            "message": "${install.adminPasswordRequiredMsg}"
          },
          {
            "min": 8,
            "max": 128,
            "message": "${install.adminPasswordLenMsg}"
          }
        ]
      }
    ]
  }
]
